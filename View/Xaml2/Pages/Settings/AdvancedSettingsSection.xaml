<UserControl x:Class="Fork.View.Xaml2.Pages.Settings.AdvancedSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10" Margin="5 5 10 5">
        <StackPanel Background="Transparent" Margin="0 10" HorizontalAlignment="Left">
            <TextBlock Text="Advanced Settings" Foreground="{DynamicResource textHeader}"
                       FontFamily="{DynamicResource Montserrat-SemiBold}" FontSize="23" Margin="95 0 5 20" />
            <StackPanel Margin="110 10 50 10" HorizontalAlignment="Left">
                <!-- Advanced checkboxes grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <CheckBox Content="Enable Snooper"
                              IsChecked="{Binding Server.ServerSettings.SnooperEnabled}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Margin="0 0 20 0" />
                    <CheckBox Content="Command Blocks"
                              IsChecked="{Binding Server.ServerSettings.EnableCommandBlock}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="1" Margin="0 0 20 0" />
                    <CheckBox Content="Force Gamemode"
                              IsChecked="{Binding Server.ServerSettings.ForceGamemode}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="2" Margin="0 0 20 0" />
                    <CheckBox Content="Enable Status"
                              IsChecked="{Binding Server.ServerSettings.EnableStatus}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="3" Margin="0 0 20 0" />
                    <CheckBox x:Name="enableRcon" Content="Enable RCon"
                              IsChecked="{Binding Server.ServerSettings.EnableRcon}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Column="1" Margin="20 0 0 0" />
                    <CheckBox Content="Broadcast Console"
                              IsChecked="{Binding Server.ServerSettings.BcastConsoleToOps}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="1" Grid.Column="1"
                              Margin="20 0 0 0" />
                    <CheckBox Content="Enforce Whitelist"
                              IsChecked="{Binding Server.ServerSettings.EnforceWhitelist}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="2" Grid.Column="1"
                              Margin="20 0 0 0" />
                    <CheckBox Content="JMX Monitoring"
                              IsChecked="{Binding Server.ServerSettings.EnableJmxMonitoring}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="3" Grid.Column="1"
                              Margin="20 0 0 0" />
                </Grid>
                <!-- RCon section (visible only when enableRcon is checked) -->
                <StackPanel Margin="0 20 0 0">
                    <CheckBox IsChecked="{Binding Server.ServerSettings.BcastRconToOps}"
                              Content="Broadcast RCon to OPs"
                              Style="{DynamicResource DefaultCheckBox}" FontSize="20"
                              HorizontalAlignment="Center" Margin="0 0 0 5" />
                    <DockPanel Height="40" Margin="0 5 0 5">
                        <Border CornerRadius="4" Width="150" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.RconPort}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="RCon Port" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40" Margin="0 5 0 5">
                        <Border CornerRadius="4" Width="150" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.RconPassword}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="RCon Password" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=enableRcon, Path=IsChecked}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=enableRcon, Path=IsChecked}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                </StackPanel>
                <!-- OP level / idle timeout / build height / world size -->
                <StackPanel Margin="0 20 0 0" MaxWidth="350">
                    <DockPanel Height="40">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.OpPermissionLevel}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="OP Permission Level" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.PlayerIdleTimeout}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Player Idle Timeout" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.MaxBuildHeight}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Allowed Build Height" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.MaxWorldSize}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Allowed World Size" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource backgroundHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
