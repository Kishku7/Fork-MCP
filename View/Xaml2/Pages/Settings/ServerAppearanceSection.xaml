<UserControl x:Class="Fork.View.Xaml2.Pages.Settings.ServerAppearanceSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:Fork.View.Xaml.Converter">
    <UserControl.Resources>
        <!-- Fixed typo from original: InverseBoolToVisiblityConverter → InverseBoolToVisibilityConverter -->
        <converter:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </UserControl.Resources>
    <Border CornerRadius="10" Margin="5 5 10 5">
        <StackPanel Background="Transparent" Margin="0 10" Width="720" HorizontalAlignment="Left">
            <TextBlock Text="Server Appearance" Foreground="{DynamicResource textHeader}"
                       FontFamily="{DynamicResource Montserrat-SemiBold}" FontSize="23" Margin="95 0 5 5" />
            <StackPanel Margin="105 30 0 0">
                <TextBlock Text="Server Resource Pack URL"
                           Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                <Border CornerRadius="4" Width="550" Height="26"
                        Background="{DynamicResource textBackground}" Margin="0 5 0 5"
                        HorizontalAlignment="Left">
                    <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.ResourcePack}"
                             Background="{DynamicResource textBackground}" BorderThickness="0"
                             Foreground="{DynamicResource backgroundDark}"
                             FontFamily="{DynamicResource Montserrat-SemiBold}"
                             FontSize="17" Height="20" />
                </Border>
                <CheckBox Content="Set SHA-1 automatically (recommended)"
                          IsChecked="{Binding Server.AutoSetSha1}"
                          Style="{DynamicResource TextCheckBox}" FontSize="20" Margin="10 5 0 0" />
                <StackPanel
                    Visibility="{Binding Server.AutoSetSha1, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="Server Resource Pack SHA-1"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="40 10 10 0" />
                    <Border CornerRadius="4" Width="510" Height="26"
                            Background="{DynamicResource textBackground}" Margin="40 5 0 5"
                            HorizontalAlignment="Left">
                        <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.ResourcePackSha1}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" Margin="0 25 0 0">
                    <TextBlock Text="Message of the day" Style="{DynamicResource CreateServerTextBlock}"
                               Margin="0 0 20 10" />
                    <Border CornerRadius="4" Width="550" DockPanel.Dock="Right" Height="50"
                            Background="{DynamicResource textBackground}">
                        <TextBox Text="{Binding Server.ServerSettings.Motd}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" TextWrapping="NoWrap" AcceptsReturn="True" AcceptsTab="True"
                                 Height="40" />
                    </Border>
                    <TextBlock Text="MOTD Generator"
                               PreviewMouseLeftButtonDown="OpenMOTDGenerator_PreviewMouseLeftButtonDown"
                               FontSize="14" Margin="0 5 0 0"
                               Cursor="Hand"
                               Foreground="{DynamicResource textLink}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" Margin="0 25 0 0">
                    <TextBlock Text="Server Icon" Style="{DynamicResource CreateServerTextBlock}"
                               Margin="0 0 20 10" />
                    <ListBox ItemsSource="{Binding ServerIcons}"
                             Style="{DynamicResource ServerIconListBox}"
                             ItemContainerStyle="{DynamicResource ServerIconListBoxItem}"
                             SelectedItem="{Binding SelectedServerIcon}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource backgroundHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
