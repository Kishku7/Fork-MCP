<UserControl x:Class="Fork.View.Xaml2.Pages.Settings.UnknownPropertiesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:Fork.View.Xaml.Converter">
    <UserControl.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converter:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </UserControl.Resources>
    <Border CornerRadius="10" Margin="5 5 10 5">
        <StackPanel Background="Transparent" Margin="0 10" HorizontalAlignment="Left">
            <TextBlock Text="Custom Properties" Foreground="{DynamicResource textHeader}"
                       FontFamily="{DynamicResource Montserrat-SemiBold}" FontSize="23" Margin="95 0 5 5" />
            <TextBlock Text="Keys present in server.properties not recognized by Fork-MCP"
                       Foreground="{DynamicResource textUnselected}" FontSize="13"
                       Margin="95 0 5 15" Opacity="0.6" />
            <StackPanel Margin="110 5 30 10" HorizontalAlignment="Left">
                <!-- Empty state -->
                <TextBlock Text="No custom properties found."
                           Foreground="{DynamicResource textUnselected}"
                           FontSize="15" Margin="0 5 0 10" Opacity="0.5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Server.ServerSettings.UnknownProperties.Count}"
                                             Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Key/value rows -->
                <ItemsControl ItemsSource="{Binding Server.ServerSettings.UnknownProperties}" HorizontalAlignment="Left">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0 4 0 4" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="240" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="460" />
                                </Grid.ColumnDefinitions>
                                <!-- Key (read-only label) -->
                                <Border Grid.Column="0" CornerRadius="4" Height="26"
                                        Background="{DynamicResource backgroundDark}">
                                    <TextBlock Text="{Binding Key}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource textUnselected}"
                                               FontFamily="{DynamicResource Montserrat-SemiBold}"
                                               FontSize="14" Margin="8 0" />
                                </Border>
                                <!-- Value (editable) -->
                                <Border Grid.Column="2" CornerRadius="4" Height="26"
                                        Background="{DynamicResource textBackground}">
                                    <TextBox Margin="5 0"
                                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="{DynamicResource textBackground}"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource backgroundDark}"
                                             FontFamily="{DynamicResource Montserrat-SemiBold}"
                                             FontSize="15" Height="20" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource backgroundHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
