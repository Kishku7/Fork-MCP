<UserControl x:Class="Fork.View.Xaml2.Pages.Settings.GeneralSettingsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10" Margin="5 5 10 5">
        <StackPanel Background="Transparent" Margin="0 20" HorizontalAlignment="Left">
            <TextBlock Text="General Settings" Foreground="{DynamicResource textHeader}"
                       FontFamily="{DynamicResource Montserrat-SemiBold}" FontSize="23" Margin="95 0 5 20" />
            <StackPanel Margin="110 10 20 10" HorizontalAlignment="Left">
                <!-- Gamemode / Difficulty / Player Slots / Ports grid (MaxRam lives in Java and Networking) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <DockPanel Height="40" Margin="0 0 20 0">
                        <ComboBox DockPanel.Dock="Right" SelectedIndex="0" Width="150"
                                  HorizontalAlignment="Left"
                                  ItemContainerStyle="{DynamicResource DefaultComboBoxItem}"
                                  FontFamily="{DynamicResource Montserrat-Bold}" FontSize="17"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Server.ServerSettings.Gamemodes}"
                                  SelectedItem="{Binding Server.ServerSettings.CurrGamemode}" />
                        <TextBlock Text="Gamemode" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40" Grid.Row="1" Margin="0 0 20 0">
                        <ComboBox DockPanel.Dock="Right" SelectedIndex="0" Width="150"
                                  HorizontalAlignment="Left"
                                  ItemContainerStyle="{DynamicResource DefaultComboBoxItem}"
                                  FontFamily="{DynamicResource Montserrat-Bold}" FontSize="17"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Server.ServerSettings.Difficulties}"
                                  SelectedItem="{Binding Server.ServerSettings.CurrDifficulty}" />
                        <TextBlock Text="Difficulty" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40" Grid.Column="1" Margin="20 0 0 0">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.MaxPlayers}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Player Slots" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40" Grid.Column="1" Grid.Row="1" Margin="20 0 0 0">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.ServerPort}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Server Port" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                    <DockPanel Height="40" Grid.Column="1" Grid.Row="2" Margin="20 0 0 0">
                        <Border CornerRadius="4" Width="100" DockPanel.Dock="Right" Height="26"
                                Background="{DynamicResource textBackground}">
                            <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.QueryPort}"
                                     Background="{DynamicResource textBackground}" BorderThickness="0"
                                     Foreground="{DynamicResource backgroundDark}"
                                     FontFamily="{DynamicResource Montserrat-SemiBold}"
                                     FontSize="17" Height="20" />
                        </Border>
                        <TextBlock Text="Query Port" TextAlignment="Right"
                                   Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 0" />
                    </DockPanel>
                </Grid>
                <!-- Checkboxes grid -->
                <Grid Margin="0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <CheckBox Content="Enable Nether" IsChecked="{Binding Server.ServerSettings.AllowNether}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Margin="0 0 20 0" />
                    <CheckBox Content="Enable PvP" IsChecked="{Binding Server.ServerSettings.Pvp}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="1" Margin="0 0 20 0" />
                    <CheckBox Content="Use Whitelist" IsChecked="{Binding Server.ServerSettings.Whitelist}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="2" Margin="0 0 20 0" />
                    <CheckBox Content="Hardcore" IsChecked="{Binding Server.ServerSettings.Hardcore}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="3" Margin="0 0 20 0" />
                    <CheckBox Content="Generate Structures"
                              IsChecked="{Binding Server.ServerSettings.GenerateStructures}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="4" Margin="0 0 20 0" />
                    <CheckBox Content="Allow Flight" IsChecked="{Binding Server.ServerSettings.AllowFlight}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="5" Margin="0 0 20 0" />
                    <CheckBox Content="Spawn Monsters" IsChecked="{Binding Server.ServerSettings.SpawnMonsters}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Column="1" Margin="20 0 0 0" />
                    <CheckBox Content="Spawn Animals" IsChecked="{Binding Server.ServerSettings.SpawnAnimals}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="1" Grid.Column="1"
                              Margin="20 0 0 0" />
                    <CheckBox Content="Spawn NPCs" IsChecked="{Binding Server.ServerSettings.SpawnNpcs}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="2" Grid.Column="1"
                              Margin="20 0 0 0" />
                    <CheckBox Content="Online Mode" IsChecked="{Binding Server.ServerSettings.OnlineMode}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="3" Grid.Column="1"
                              Margin="20 0 0 0" />
                    <CheckBox Content="Enable Query" IsChecked="{Binding Server.ServerSettings.EnableQuery}"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Grid.Row="4" Grid.Column="1"
                              Margin="20 0 0 0" />
                </Grid>
                <!-- Spawn protection / view distance / entity broadcast range -->
                <Grid Margin="0 10">
                    <StackPanel>
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Spawn Protection" TextAlignment="Right"
                                       Style="{DynamicResource CreateServerTextBlock}" />
                            <Border Grid.Column="1" Margin="10 0 3 0" CornerRadius="4" Width="42" Height="26"
                                    Background="{DynamicResource textBackground}">
                                <TextBox Text="{Binding Server.ServerSettings.SpawnProtection}"
                                         Background="{DynamicResource textBackground}" BorderThickness="0"
                                         Foreground="{DynamicResource backgroundDark}" Margin="5 0"
                                         FontFamily="{DynamicResource Montserrat-SemiBold}"
                                         FontSize="17" Height="20" ScrollViewer.CanContentScroll="False" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="Blocks" Style="{DynamicResource CreateServerTextBlock}" />
                            <TextBlock Grid.Row="1" Text="View Distance" TextAlignment="Right"
                                       Style="{DynamicResource CreateServerTextBlock}" />
                            <Border Grid.Row="1" Grid.Column="1" Margin="10 0 3 0" CornerRadius="4" Width="42"
                                    Height="26" Background="{DynamicResource textBackground}">
                                <TextBox Text="{Binding Server.ServerSettings.ViewDistance}"
                                         Background="{DynamicResource textBackground}" BorderThickness="0"
                                         Foreground="{DynamicResource backgroundDark}" Margin="5 0"
                                         FontFamily="{DynamicResource Montserrat-SemiBold}"
                                         FontSize="17" Height="20" />
                            </Border>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Chunks"
                                       Style="{DynamicResource CreateServerTextBlock}" />
                            <TextBlock Grid.Row="2" Text="Entity Broadcast Range" TextAlignment="Right"
                                       Style="{DynamicResource CreateServerTextBlock}" />
                            <Border Grid.Row="2" Grid.Column="1" Margin="10 0 3 0" CornerRadius="4" Width="42"
                                    Height="26" Background="{DynamicResource textBackground}">
                                <TextBox Text="{Binding Server.ServerSettings.EntityBroadcastRangePercentage}"
                                         Background="{DynamicResource textBackground}" BorderThickness="0"
                                         Foreground="{DynamicResource backgroundDark}" Margin="5 0"
                                         FontFamily="{DynamicResource Montserrat-SemiBold}"
                                         FontSize="17" Height="20" />
                            </Border>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Percent"
                                       Style="{DynamicResource CreateServerTextBlock}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </StackPanel>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource backgroundHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
