<UserControl x:Class="Fork.View.Xaml2.Pages.Settings.JavaNetworkingSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Fork.View.Xaml2.Controls"
             x:Name="ThisControl">
    <Border CornerRadius="10" Margin="5 5 10 5">
        <StackPanel Background="Transparent" Margin="0 10" Width="720" HorizontalAlignment="Left">
            <TextBlock Text="Java and Networking" Foreground="{DynamicResource textHeader}"
                       FontFamily="{DynamicResource Montserrat-SemiBold}" FontSize="23" Margin="95 0 5 20" />
            <StackPanel Margin="110 10 50 10" HorizontalAlignment="Left">
                <StackPanel>
                    <CheckBox IsChecked="{Binding Server.ServerSettings.UseNativeTransport}"
                              Content="Use Native Transport"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Margin="0 0 20 0" />
                    <CheckBox IsChecked="{Binding Server.ServerSettings.PreventProxyConnections}"
                              Content="Prevent Proxy Connections"
                              Style="{DynamicResource TextCheckBox}" FontSize="20" Margin="0 0 20 0" />
                </StackPanel>
                <!-- Numeric settings: MaxTickTime, NetworkCompression, RateLimit, MaxRam -->
                <Grid Margin="0 20 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Max Tick Time" TextAlignment="Right"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 0 10 5" />
                    <Border Grid.Column="1" CornerRadius="4" Width="100" Height="26"
                            Background="{DynamicResource textBackground}" Margin="0 5 0 5">
                        <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.MaxTickTime}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                    <TextBlock Grid.Row="1" Text="Network Compression" TextAlignment="Right"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 5 10 5" />
                    <Border Grid.Row="1" Grid.Column="1" CornerRadius="4" Width="100" Height="26"
                            Background="{DynamicResource textBackground}" Margin="0 5 0 5">
                        <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.NetworkCompressionThreshold}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                    <TextBlock Grid.Row="2" Text="Rate Limit" TextAlignment="Right"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 5 10 5" />
                    <Border Grid.Row="2" Grid.Column="1" CornerRadius="4" Width="100" Height="26"
                            Background="{DynamicResource textBackground}" Margin="0 5 0 5">
                        <TextBox Margin="5 0" Text="{Binding Server.ServerSettings.RateLimit}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                    <TextBlock Grid.Row="3" Text="Max RAM" TextAlignment="Right"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 5 10 5" />
                    <Border Grid.Row="3" Grid.Column="1" CornerRadius="4" Width="100" Height="26"
                            Background="{DynamicResource textBackground}" Margin="0 5 0 5">
                        <TextBox Margin="5 0" Text="{Binding Server.JavaSettings.MaxRam}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text=" MB"
                               Style="{DynamicResource CreateServerTextBlock}" />
                </Grid>
                <!-- Java version selector and startup parameters -->
                <StackPanel Margin="0 20 0 0">
                    <TextBlock Text="Java Version"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 5 10 5" />
                    <ComboBox Width="420" HorizontalAlignment="Left" Height="30"
                              ItemsSource="{Binding KnownJavaVersions, ElementName=ThisControl}"
                              SelectedValue="{Binding Server.JavaSettings.PreferredMajorVersion, Mode=TwoWay}"
                              SelectedValuePath="Major"
                              DisplayMemberPath="DisplayLabel"
                              Style="{DynamicResource DefaultComboBox}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Foreground" Value="{DynamicResource foregroundDisabled}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    <TextBlock Text="Custom Startup Parameters"
                               Style="{DynamicResource CreateServerTextBlock}" Margin="0 15 10 5" />
                    <Border CornerRadius="4" Width="420" Height="26"
                            Background="{DynamicResource textBackground}" Margin="0 5 0 5"
                            HorizontalAlignment="Left">
                        <TextBox Margin="5 0" Text="{Binding Server.JavaSettings.StartupParameters}"
                                 Background="{DynamicResource textBackground}" BorderThickness="0"
                                 Foreground="{DynamicResource backgroundDark}"
                                 FontFamily="{DynamicResource Montserrat-SemiBold}"
                                 FontSize="17" Height="20" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource backgroundHover}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</UserControl>
