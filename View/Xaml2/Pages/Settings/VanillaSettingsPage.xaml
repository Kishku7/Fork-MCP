<Page x:Class="Fork.View.Xaml2.Pages.Settings.VanillaSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Fork.View.Xaml2.Controls"
      xmlns:settings="clr-namespace:Fork.View.Xaml2.Pages.Settings"
      mc:Ignorable="d"
      d:DesignHeight="2000" d:DesignWidth="800"
      Title="MCSettingsPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="20" />
        </Grid.RowDefinitions>
        <ScrollViewer Margin="10 20 5 10" Style="{DynamicResource SettingsScrollViewer}">
            <controls:StretchyWrapPanel>
                <settings:GeneralSettingsSection />
                <settings:ServerAppearanceSection />
                <settings:AdvancedSettingsSection />
                <settings:JavaNetworkingSection />
                <settings:UnknownPropertiesSection />
            </controls:StretchyWrapPanel>
        </ScrollViewer>
        <TextBlock Grid.Row="1" Text="All Changes will be saved automatically" HorizontalAlignment="Center" />
    </Grid>
</Page>
